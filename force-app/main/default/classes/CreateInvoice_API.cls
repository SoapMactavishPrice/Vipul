@RestResource(urlMapping = '/CreateInvoice')
global class CreateInvoice_API {
    
    @HttpPost
    global static void doPost() {
        RestRequest request = RestContext.request;
        RestResponse response = RestContext.response;
        String jSONRequestBody = request.requestBody.toString().replace('\n', '');

        // ------------------- API LOG to track the request -------------------
        API_Log__c api_log = new API_Log__c();
        api_log.API_log_Name__c = 'CreateInvoiceAPI';
        api_log.Request__c = jSONRequestBody;
        api_log.Request_Created_Time__c = DateTime.now();

        List<JSON2ApexSaveWebToLead> jsonObj = JSON2ApexSaveWebToLead.parse(jSONRequestBody);
        System.debug('======----->jsonObj' + jsonObj);

        List<Invoice__c> invoiceToInsert = new List<Invoice__c>();
        List<Invoice_Line_Item__c> invoiceLIToInsert = new List<Invoice_Line_Item__c>();

        try {

            Set<String> customerCodeSet = new Set<String>();
            Set<String> orderNumberSet = new Set<String>();
            Set<String> itemNumberSet = new Set<String>();

            for (JSON2ApexSaveWebToLead obj : jsonObj) {
                if (String.isBlank(obj.Customer_Code) || String.isBlank(obj.Sale_Order_Number)) {
                    throw new IllegalArgumentException('Customer_Code & Sales_Order_Number cannot be blank');
                }
                customerCodeSet.add(obj.Customer_Code);
                orderNumberSet.add(obj.Sale_Order_Number);
                for (InvoiceLineItemWrapper z : obj.InvoiceLineItem) {
                    if (String.isBlank(z.Item_Number)) {
                        throw new IllegalArgumentException('Item_Number cannot be blank');
                    }
                    itemNumberSet.add(z.Item_Number);
                }
            }

            // Get Customer
            List<Account> accList = [
                SELECT Id, Name, Customer_Code__c
                FROM Account
                WHERE Customer_Code__c != null
                AND Customer_Code__c IN :customerCodeSet
            ];

            Map<String, String> customerCodeIdMap = new Map<String, String>();

            for (Account acc : accList) {
                customerCodeIdMap.put(acc.Customer_Code__c, acc.Id);
            }

            // Get Order data
            List<Order> ordList = [
                SELECT Id, Name, Oracle_Sales_Order_No__c
                FROM Order
                WHERE Oracle_Sales_Order_No__c != null
                AND Oracle_Sales_Order_No__c IN :orderNumberSet
            ];

            Map<String, Object> orderNumOrdIdMap = new Map<String, Object>();

            for (Order ord : ordList) {
                orderNumOrdIdMap.put(ord.Oracle_Sales_Order_No__c, ord.Id);
            }

            // Get Product data
            List<Product2> productList = [
                SELECT Id, Name, Item_No__c
                FROM Product2
                WHERE Item_No__c != null
                AND Item_No__c IN :itemNumberSet
            ];

            Map<String, Object> prodCodeProdIdMap = new Map<String, Object>();

            for (Product2 p : productList) {
                prodCodeProdIdMap.put(p.Item_No__c, p.Id);
            }

            // Insert Invoices
            for (JSON2ApexSaveWebToLead obj : jsonObj) {
                Invoice__c inv = new Invoice__c();
                if (customerCodeIdMap.containskey(obj.Customer_Code)) {
                    inv.Account__c = String.valueOf(customerCodeIdMap.get(obj.Customer_Code));
                } else {
                    throw new IllegalArgumentException('No Customer_Code found');
                }
                if (orderNumOrdIdMap.containskey(obj.Sale_Order_Number)) {
                    inv.Order__c = String.valueOf(orderNumOrdIdMap.get(obj.Sale_Order_Number));
                } else {
                    throw new IllegalArgumentException('No Sale_Order_Number found');
                }
                inv.Name = obj.Invoice_Number;
                // inv.Invoice_No__c = obj.Invoice_Number;
                inv.Document_Type__c = obj.Document_Type;
                inv.Transaction_Type__c = obj.Transaction_Type;
                inv.ARI_Series__c = obj.ARI_Series;
                inv.ARI_No__c = obj.ARI_No;
                inv.ARI_Date__c = Date.valueOf(obj.ARI_Date);
                inv.ARI_Status__c = obj.ARI_Status;
                if (!String.isBlank(obj.Sales_Employee)) {
                    // inv.Sales_Employee__c = obj.Sales_Employee;
                }
                inv.Prepared_by__c = obj.Prepared_by;
                inv.CustomerCode__c = obj.Customer_Code;
                inv.CustomerName__c = obj.Customer_Name;
                inv.Customer_Group__c = obj.Customer_Group;
                if (!String.isBlank(obj.State)) {
                    inv.State__c = obj.State;
                }
                if (!String.isBlank(obj.Country)) {
                    inv.Country__c = obj.Country;
                }
                inv.Exchange_Rate__c = Decimal.valueOf(obj.Exchange_Rate);
                inv.GST_No__c = obj.GST_No;
                inv.PAN_No__c = obj.PAN_No;
                inv.Customer_Ref_No__c = obj.Customer_Ref_No;
                inv.Customer_Ref_Date__c = Date.valueOf(obj.Customer_Ref_Date);
                inv.PaymentTerms__c = obj.paymentTerms;
                inv.Branch_Name__c = obj.BranchName;
                inv.ItemGroupCode__c = obj.ItemGroupCode;
                inv.ItemGroupName__c = obj.ItemGroupName;
                inv.PaymentCode__c = obj.PaymentCode;
                inv.PaymentName__c = obj.PaymentName;
                inv.Disc_Doc__c = obj.Disc_Doc;
                inv.Round_Amt__c = obj.Round_Amt;
                inv.Received_Payment__c = obj.Received_Payment;
                inv.DocStatus__c = obj.DocStatus;
                inv.Payment_Status__c = obj.Payment_Status;
                invoiceToInsert.add(inv);
            }

            if (invoiceToInsert.size() > 0) {
                insert invoiceToInsert;
                for (Integer i = 0; i < jsonObj.size(); i++) {
                    Invoice__c inv = invoiceToInsert[i];
                    JSON2ApexSaveWebToLead req = jsonObj[i];
                    for (InvoiceLineItemWrapper z : req.InvoiceLineItem) {
                        Invoice_Line_Item__c ili = new Invoice_Line_Item__c();
                        ili.Invoice__c = inv.Id;
                        ili.Name = 'INVLI-'+inv.Name;
                        if (prodCodeProdIdMap.containskey(z.Item_Number)) {
                            ili.ItemName__c = String.valueOf(prodCodeProdIdMap.get(z.Item_Number));
                        } else {
                            throw new IllegalArgumentException('No Item_Number found');
                        }
                        ili.Quantity__c = checkNullDecimal(z.Quantity);
                        ili.ItemCode__c = z.Item_Number;
                        ili.ItemGroup__c = z.Item_Group;
                        ili.Dics_Item__c = z.Dics_Item;
                        ili.Foreign_Name_of_Item_Master__c = z.Foreign_Name_of_Item_Master;
                        ili.Additional_Identifier__c = z.Additional_Identifier;
                        ili.UOM2__c = z.UoM;
                        ili.HSN__c = z.HSN;
                        ili.SAC__c = z.SAC;
                        ili.Price_after_Discount__c = checkNullDecimal(z.Price_after_Discount);
                        ili.Line_Total_Before_Tax__c = checkNullDecimal(z.Line_Total_Before_Tax);
                        ili.Line_Total_Before_Tax_INR__c = checkNullDecimal(z.Line_Total_Before_Tax_INR);
                        ili.TaxCode__c = z.TaxCode;
                        ili.GST__c = checkNullDecimal(z.GST);
                        ili.CGST_Amount__c = checkNullDecimal(z.CGST_Amount);
                        ili.SGST_Amount__c = checkNullDecimal(z.SGST_Amount);
                        ili.IGST_Amount__c = checkNullDecimal(z.IGST_Amount);
                        ili.UTGST_Amount__c = checkNullDecimal(z.UTGST_Amount);
                        ili.Total_GST_Amount__c = checkNullDecimal(z.Total_GST_Amount);
                        ili.Revenue_Account__c = z.Revenue_Account;
                        ili.File_No__c = z.File_No;
                        ili.B_L_No__c = z.B_L_No;
                        ili.B_L_Date__c = Date.valueOf(z.B_L_Date);
                        ili.Shipping_No__c = z.Shipping_No;
                        ili.Shipping_Date__c = Date.valueOf(z.Shipping_Date);
                        ili.Port_Code__c = z.Port_Code;
                        ili.Logistic_Invoice_No__c = z.Logistic_Invoice_No;
                        ili.Logistic_Invoice_Date__c = Date.valueOf(z.Logistic_Invoice_Date);
                        ili.SB_Taxable_Amount__c = checkNullDecimal(z.SB_Taxable_Amount);
                        ili.SB_IGST_Amount__c = checkNullDecimal(z.SB_IGST_Amount);
                        ili.Warehouse_Name__c = z.Warehouse_Name;
                        ili.Location_Name__c = z.Location_Name;
                        // ili.Branch_Name__c = z.Branch_Name;
                        ili.Segment__c = z.Segment;
                        invoiceLIToInsert.add(ili);
                    }
                }
                if (invoiceLIToInsert.size() > 0) {
                    insert invoiceLIToInsert;
                }
            }

            System.debug('-->Data Saved Successfully');
            // ------------------- Send the Success Response -------------------
            Map < string, object > successResMap = new Map < string, object > ();
            successResMap.put('status', 'success');
            successResMap.put('message', 'Invoice Inserted Successfully');
            String resp = JSON.serialize(successResMap);
            response.responseBody = Blob.valueOf(resp);
            response.addHeader('Content-Type', 'application/json');
            response.statusCode = 200;

            api_log.Status__c = 'Success';
            api_log.Response_Code__c = '200';
            api_log.Response__c = String.valueOf(resp);
            api_log.Response_Time__c = Datetime.now();
            
        } catch (Exception e) {
            System.debug('Catch Error' + e.getStackTraceString());
            System.debug('Catch Error' + e.getMessage());
            System.debug('Catch Error' + e.getlineNumber());

            // ------------------- Create Response Map -------------------
            Map < string, string > errorResMap = new Map < string, string > ();
            errorResMap.put('status', 'Something went wrong');
            errorResMap.put('message', e.getMessage());

            // ------------------- Send Response Map -------------------
            String resp = JSON.serialize(errorResMap);
            response.responseBody = Blob.valueOf(resp);
            response.addHeader('Content-Type', 'application/json');
            response.statusCode = 400;

            api_log.Status__c = 'Failure';
            api_log.Response_Code__c = '400';
            api_log.Exception_Description__c = 'Line Number : ' + e.getLineNumber() + ' \n\n ' + e.getMessage() + '\n\n' + e.getStackTraceString();
            api_log.Response_Time__c = Datetime.now();

        }

        insert api_log;
    }

    public static Decimal checkNullDecimal (String val){

        if(val == null || val == ''){
            return 0.0;
        } else {
            return Decimal.valueOf(val);
        }
    }

